        <mxCell id="vqY8qahnmonNA0wLGMaj-126" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Step 2: 사라진 트래킹 제거&#xa;visible_tracks=[t for i,t in enumerate(tracked_vehicles)&#xa;  if i in matched_track_indices]&#xa;[미매칭 차량 → 즉시 타이머 리셋]" vertex="1">
