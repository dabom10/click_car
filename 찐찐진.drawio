        <mxCell id="vqY8qahnmonNA0wLGMaj-124" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Step 1: IoU 매칭&#xa;for t_idx,track in enumerate(tracked_vehicles):&#xa;  for p_idx,(car_det,_) in enumerate(validated_pairs):&#xa;    iou=inter/(area_a+area_b-inter)&#xa;  best_iou≥CAR_IOU_THRESH(0.30) → 갱신" vertex="1">
